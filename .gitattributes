# github-pick is a "talk to your agent" project folder — an instruction file plus a
# zero-build static dashboard — not a code library. Hide the GitHub "Languages" bar by
# excluding everything from Linguist's language statistics.
*.html  linguist-documentation
*.md    linguist-documentation
*.js    linguist-detectable=false
*.mjs   linguist-detectable=false
*.json  linguist-detectable=false
*.css   linguist-detectable=false

# data.js is generated by scripts/build-data.mjs — never hand-edited.
data.js linguist-generated
